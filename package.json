{
  "name": "discourse-projects",
  "version": "0.0.0",
  "repository": "https://github.com/ICIJ/discourse-projects/",
  "author": "ICIJ",
  "license": "MIT",
  "scripts": {
    "lint": "yarn eslint --ext .js,.js.es6 --no-error-on-unmatched-pattern testjavascripts assets/javascripts",
    "lint:fix": "yarn eslint --fix --ext .js,.js.es6 --no-error-on-unmatched-pattern testjavascripts assets/javascripts",
    "ember": "yarn ember-template-lint --no-error-on-unmatched-pattern assets/javascripts",
    "prettier:assets": "yarn prettier --list-different 'assets/**/*.{scss,js,es6,hbs}'",
    "prettier:assets:fix": "yarn prettier --write 'assets/**/*.{scss,js,es6,hbs}'",
    "prettier:test": "yarn prettier --list-different 'test/**/*.{js,es6}'",
    "prettier:test:fix": "yarn prettier --write 'test/**/*.{js,es6}'"
  },
  "devDependencies": {
    "@discourse/lint-configs": "^1.0.0",
    "ember-template-lint": "^5.11.2",
    "eslint": "^8.52.0",
    "prettier": "^2.8.8"
  }
}
